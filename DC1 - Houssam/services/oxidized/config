---
username: admin
password: DevCloud2025!
model: ios
resolve_dns: true
interval: 3600
use_syslog: false
debug: false
threads: 30
timeout: 20
retries: 3
prompt: !ruby/regexp /^([\w.@-]+[#>]\s*)$/
rest: 0.0.0.0:8888
pid: "/home/oxidized/.config/oxidized/pid"

output:
  default: git
  git:
    user: Houssam
    email: hsmprv2006@gmail.com
    repo: "/home/oxidized/.config/oxidized/oxidized.git"

source:
  default: csv
  csv:
    file: "/home/oxidized/.config/oxidized/router.db"
    delimiter: !ruby/regexp /:/
    map:
      name: 0
      ip: 1
      model: 2

model_map:
  cisco: ios
  juniper: junos
  mikrotik: routeros
  frr: frr

hooks:
  push_to_git:
    type: githubrepo
    events: [post_store]
    remote_repo: https://Houssam:TON_TOKEN_GITHUB_ICI@github.com/HSM2006/R-seaux-Data-Center.git
    remote_branch: configs-backup
    username: Houssam
    password: TON_TOKEN_GITHUB_ICI
# ------------------------------------------------------------------
# SECURITE : ce fichier est versionne dans Git, donc PAS de vrai token
# ici (un ancien token avait été commité par erreur et reste visible
# dans l'historique Git — il DOIT être révoqué côté GitHub :
# Settings > Developer settings > Personal access tokens > Delete).
#
# Le fichier réellement utilisé par le container est
# dc1/services/oxidized/config.local (mêmes lignes, avec le vrai
# token), volontairement absent du repo (.gitignore) et bind-monté à
# la place de celui-ci dans docker-compose.yml. Pour le recréer sur la
# VM : cp config config.local, puis remplacer TON_TOKEN_GITHUB_ICI par
# le token réel (scope "repo" uniquement, jamais "admin" ou "delete_repo").
# ------------------------------------------------------------------
