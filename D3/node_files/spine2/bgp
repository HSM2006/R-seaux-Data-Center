#!/usr/bin/vtysh -f
!
router bgp 65001
  no bgp ebgp-requires-policy
  no bgp default ipv4-unicast
  bgp default show-hostname
  bgp default show-nexthop-hostname
  ! Consider AS paths of same length but with different AS as ECMP candidates
  bgp bestpath as-path multipath-relax

  bgp router-id 10.255.0.253
  bgp cluster-id 10.255.0.253
!
  neighbor 10.255.0.254 remote-as 65001
  neighbor 10.255.0.254 description spine1
  neighbor 10.255.0.254 update-source lo
!
  neighbor 10.255.0.1 remote-as 65001
  neighbor 10.255.0.1 description leaf1
  neighbor 10.255.0.1 update-source lo
!
  neighbor 10.255.0.2 remote-as 65001
  neighbor 10.255.0.2 description leaf2
  neighbor 10.255.0.2 update-source lo
!
  neighbor 10.255.0.3 remote-as 65001
  neighbor 10.255.0.3 description leaf3
  neighbor 10.255.0.3 update-source lo
!
 address-family ipv4 unicast
!

  network 10.255.0.253/32
!
  neighbor 10.255.0.254 activate
  neighbor 10.255.0.254 next-hop-self
  no neighbor 10.255.0.254 send-community all
  neighbor 10.255.0.254 send-community standard
  neighbor 10.255.0.254 send-community large
  neighbor 10.255.0.254 send-community extended
!
  neighbor 10.255.0.1 activate
  neighbor 10.255.0.1 next-hop-self
  neighbor 10.255.0.1 route-reflector-client
  no neighbor 10.255.0.1 send-community all
  neighbor 10.255.0.1 send-community standard
  neighbor 10.255.0.1 send-community large
  neighbor 10.255.0.1 send-community extended
!
  neighbor 10.255.0.2 activate
  neighbor 10.255.0.2 next-hop-self
  neighbor 10.255.0.2 route-reflector-client
  no neighbor 10.255.0.2 send-community all
  neighbor 10.255.0.2 send-community standard
  neighbor 10.255.0.2 send-community large
  neighbor 10.255.0.2 send-community extended
!
  neighbor 10.255.0.3 activate
  neighbor 10.255.0.3 next-hop-self
  neighbor 10.255.0.3 route-reflector-client
  no neighbor 10.255.0.3 send-community all
  neighbor 10.255.0.3 send-community standard
  neighbor 10.255.0.3 send-community large
  neighbor 10.255.0.3 send-community extended
!
!
do write