#!/usr/bin/vtysh -f
!
! OSPFv2 FRR configuration
!
router ospf
 ospf router-id 10.255.0.2
 timers throttle spf 10 50 500
 timers throttle lsa all 100
 timers lsa min-arrival 100


exit
!
interface lo
! 
 ip ospf area 0.0.0.0
!
interface eth1
! leaf2 -> spine1
 ip ospf area 0.0.0.0
 ip ospf network point-to-point
!
interface eth2
! leaf2 -> spine2
 ip ospf area 0.0.0.0
 ip ospf network point-to-point
!

!
do write