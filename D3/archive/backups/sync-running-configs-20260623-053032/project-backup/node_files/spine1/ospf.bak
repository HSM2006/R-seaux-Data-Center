#!/usr/bin/vtysh -f
!
! OSPFv2 FRR configuration
!
router ospf
 ospf router-id 10.255.0.254
 timers throttle spf 10 50 500
 timers throttle lsa all 100
 timers lsa min-arrival 100


exit
!
interface lo
! 
 ip ospf area 0.0.0.0
!
interface eth1
! spine1 -> leaf1
 ip ospf area 0.0.0.0
 ip ospf network point-to-point
!
interface eth2
! spine1 -> leaf2
 ip ospf area 0.0.0.0
 ip ospf network point-to-point
!
interface eth3
! spine1 -> leaf3
 ip ospf area 0.0.0.0
 ip ospf network point-to-point
!
interface eth4
! spine1 -> stub
 ip ospf area 0.0.0.0
 ip ospf passive
!

!
do write