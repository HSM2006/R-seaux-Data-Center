!
service routing protocols model multi-agent
!
hostname spine1
!
ip routing
!
interface Ethernet1
   no switchport
   ip address 172.16.1.0/31
   no shutdown
!
interface Ethernet2
   no switchport
   ip address 172.16.1.2/31
   no shutdown
!
interface Ethernet3
   no switchport
   ip address 172.16.1.4/31
   no shutdown
!
! Lien P2P vers la VM Debian (AS 65002, IP 172.16.2.2)
interface Ethernet4
   no switchport
   ip address 172.16.2.1/30
   no shutdown
!
interface Loopback0
   ip address 172.16.255.3/32
!
router bgp 65000
   router-id 172.16.255.3
   no bgp default ipv4-unicast
   !
   ! Peer group iBGP UNDERLAY pour les leafs
   neighbor UNDERLAY peer group
   neighbor UNDERLAY remote-as 65000
   neighbor 172.16.1.1 peer group UNDERLAY
   neighbor 172.16.1.3 peer group UNDERLAY
   neighbor 172.16.1.5 peer group UNDERLAY
   !
   ! Peer eBGP vers la VM Debian (border, AS 65002)
   neighbor 172.16.2.2 remote-as 65001
   neighbor 172.16.2.2 description VM-Debian-Host
   !
   address-family ipv4
      neighbor UNDERLAY activate
      neighbor UNDERLAY next-hop-self
      neighbor UNDERLAY route-reflector-client
      neighbor 172.16.2.2 activate
      ! Annonce les services DC2 a la VM
      network 172.20.2.0/24
   !
   address-family evpn
      neighbor UNDERLAY activate
      neighbor UNDERLAY route-reflector-client
!
end
