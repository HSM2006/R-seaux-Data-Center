!
service routing protocols model multi-agent
!
hostname leaf1
!
ip routing
!
vlan 200
   name SERVICES_DC2
!
interface Ethernet1
   no switchport
   ip address 172.16.1.1/31
   no shutdown
!
interface Ethernet2
   no switchport
   ip address 172.16.1.7/31
   no shutdown
!
interface Ethernet3
   switchport access vlan 200
   no shutdown
!
interface Ethernet4
   switchport access vlan 200
   no shutdown
!
interface Loopback0
   ip address 172.16.255.14/32
!
interface Vlan200
   ip address 172.20.2.254/24
!
interface Vxlan1
   vxlan source-interface Loopback0
   vxlan udp-port 4789
   vxlan vlan 200 vni 10200
   ! Workaround bug auto-discovery cEOS 4.33.1F (voir README)
   vxlan vlan 200 flood vtep 172.16.255.15 172.16.255.16
!
router bgp 65000
   router-id 172.16.255.14
   no bgp default ipv4-unicast
   neighbor UNDERLAY peer group
   neighbor UNDERLAY remote-as 65000
   neighbor 172.16.1.0 peer group UNDERLAY
   neighbor 172.16.1.6 peer group UNDERLAY
   !
   address-family ipv4
      neighbor UNDERLAY activate
      network 172.16.255.14/32
      network 172.20.2.0/24
   !
   address-family evpn
      neighbor UNDERLAY activate
   !
   vlan 200
      rd 172.16.255.14:200
      route-target both 200:200
      redistribute learned
!
end
