!
service routing protocols model multi-agent
!
hostname leaf3
!
ip routing
!
vlan 200
   name SERVICES_DC2
!
interface Ethernet1
   no switchport
   ip address 172.16.1.5/31
   no shutdown
!
interface Ethernet2
   no switchport
   ip address 172.16.1.11/31
   no shutdown
!
interface Ethernet3
   switchport access vlan 200
   no shutdown
!
interface Ethernet4
   switchport access vlan 200
   no shutdown
!
interface Loopback0
   ip address 172.16.255.16/32
!
interface Vxlan1
   vxlan source-interface Loopback0
   vxlan udp-port 4789
   vxlan vlan 200 vni 10200
   vxlan vlan 200 flood vtep 172.16.255.14 172.16.255.15
!
router bgp 65000
   router-id 172.16.255.16
   no bgp default ipv4-unicast
   neighbor UNDERLAY peer group
   neighbor UNDERLAY remote-as 65000
   neighbor 172.16.1.4 peer group UNDERLAY
   neighbor 172.16.1.10 peer group UNDERLAY
   !
   address-family ipv4
      neighbor UNDERLAY activate
      network 172.16.255.16/32
   !
   address-family evpn
      neighbor UNDERLAY activate
   !
   vlan 200
      rd 172.16.255.16:200
      route-target both 200:200
      redistribute learned
!
end
