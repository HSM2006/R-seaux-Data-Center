!
service routing protocols model multi-agent
!
hostname spine2
!
ip routing
!
interface Ethernet1
   no switchport
   ip address 172.16.1.6/31
   no shutdown
!
interface Ethernet2
   no switchport
   ip address 172.16.1.8/31
   no shutdown
!
interface Ethernet3
   no switchport
   ip address 172.16.1.10/31
   no shutdown
!
! Lien P2P vers la VM Debian (AS 65002, IP 172.16.2.6)
interface Ethernet4
   no switchport
   ip address 172.16.2.5/30
   no shutdown
!
interface Loopback0
   ip address 172.16.255.4/32
!
router bgp 65000
   router-id 172.16.255.4
   no bgp default ipv4-unicast
   !
   neighbor UNDERLAY peer group
   neighbor UNDERLAY remote-as 65000
   neighbor 172.16.1.7 peer group UNDERLAY
   neighbor 172.16.1.9 peer group UNDERLAY
   neighbor 172.16.1.11 peer group UNDERLAY
   !
   neighbor 172.16.2.6 remote-as 65002
   neighbor 172.16.2.6 description VM-Debian-Host
   !
   address-family ipv4
      neighbor UNDERLAY activate
      neighbor UNDERLAY next-hop-self
      neighbor UNDERLAY route-reflector-client
      neighbor 172.16.2.6 activate
      network 172.20.2.0/24
   !
   address-family evpn
      neighbor UNDERLAY activate
      neighbor UNDERLAY route-reflector-client
!
end
